# Copy this file to .env.local and fill in real values there.
# .env.local is gitignored — never commit real secrets.

# OpenAI (provided by AIM)
OPENAI_API_KEY=
# Optional — only needed if your key is issued through a proxy/gateway
# (e.g. a Vocareum-provided key) rather than directly against OpenAI.
# For Vocareum specifically, this is typically https://openai.vocareum.com/v1
# — check the AI icon in your Vocareum lab menu for the exact value.
OPENAI_BASE_URL=

# Supabase — from Project Settings > API (or the "Connect" dialog)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key — server-side only, NEVER exposed to the browser
SUPABASE_SECRET_KEY=
